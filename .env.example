# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# SQLite para desarrollo local. En producción puedes usar PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/cesga_db
DATABASE_URL=sqlite:///./cesga_simulator.db

# ─── APLICACIÓN ───────────────────────────────────────────────────────────────
# En producción: DEBUG=False
DEBUG=True
LOG_LEVEL=INFO
API_TITLE=CESGA Supercomputer Simulator
API_VERSION=1.0.0

# ─── SIMULACIÓN DE JOBS ───────────────────────────────────────────────────────
# Tiempo en segundos entre transiciones de estado
# PENDING → RUNNING
PENDING_TO_RUNNING_DELAY=5
# RUNNING → COMPLETED
RUNNING_TO_COMPLETED_DELAY=5

# ─── LÍMITES DE HARDWARE ──────────────────────────────────────────────────────
MAX_GPUS_PER_JOB=4
MAX_MEMORY_GB=256
MAX_CPUS_PER_JOB=64

# ─── CORS ─────────────────────────────────────────────────────────────────────
# En desarrollo: acepta cualquier origen
# CORS_ORIGINS=["*"]
# En producción: restringe al dominio de tu frontend
# CORS_ORIGINS=["https://tu-frontend.com", "https://app.tudominio.es"]
CORS_ORIGINS=["*"]
